## Local Docker development defaults.
## Copy this file to .env before running docker compose.

## Environment
NODE_ENV=development
TZ=UTC

## Application
APP_NAME="NestJS API"
APP_URL=http://localhost:8000
APP_PORT=8000
APP_DEBUG=false
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_LOG_LEVEL=debug
APP_LOG_SERVICE=console
APP_CORS_ORIGIN=http://localhost:5173,http://localhost:3000
APP_SECURE_HEADER_ORIGIN=http://localhost:3000,http://localhost:5173

## Database
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=boilerplate
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=
POSTGRES_PORT=5432

## Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispass
REDIS_TLS_ENABLED=false

## Mailer
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_IGNORE_TLS=true
MAIL_SECURE=false
MAIL_REQUIRE_TLS=false
MAIL_DEFAULT_EMAIL=noreply@example.com
MAIL_DEFAULT_NAME=No Reply
MAIL_CLIENT_PORT=8025
MAILPIT_MAX_MESSAGES=5000

## pgAdmin
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me

## Authentication
## Replace all secrets for shared environments and production.
AUTH_JWT_SECRET=change-me-admin-jwt-secret
AUTH_JWT_TOKEN_EXPIRES_IN=1d
AUTH_REFRESH_SECRET=change-me-admin-refresh-secret
AUTH_REFRESH_TOKEN_EXPIRES_IN=365d
AUTH_FORGOT_SECRET=change-me-admin-forgot-secret
AUTH_FORGOT_TOKEN_EXPIRES_IN=15m
AUTH_CONFIRM_EMAIL_SECRET=change-me-admin-confirm-email-secret
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d
AUTH_PORTAL_URL=http://localhost:5173

## User Authentication
USER_AUTH_JWT_SECRET=change-me-user-jwt-secret
USER_AUTH_JWT_TOKEN_EXPIRES_IN=2m
USER_AUTH_REFRESH_SECRET=change-me-user-refresh-secret
USER_AUTH_REFRESH_TOKEN_EXPIRES_IN=365d
USER_AUTH_FORGOT_SECRET=change-me-user-forgot-secret
USER_AUTH_FORGOT_TOKEN_EXPIRES_IN=7d
USER_AUTH_CONFIRM_EMAIL_SECRET=change-me-user-confirm-email-secret
USER_AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

AUTH_PORTAL_RESET_PASSWORD_URL=http://localhost:5173/reset-password
## Public origin of the client website. Used by API redirects after user OAuth/verification flows.
USER_AUTH_CLIENT_URL=http://localhost:3000
## Client reset-password page used in user forgot-password emails.
USER_AUTH_CLIENT_RESET_PASSWORD_URL=http://localhost:3000/auth/reset-password

## Google OAuth
## Google OAuth app credentials for user/client login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
## Must match the authorized redirect URI configured in Google Cloud Console.
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:8000/api/v1/user/auth/social/google/callback

## Sentry
SENTRY_DNS_NESTJS=
SENTRY_ENVIRONMENT=local
SENTRY_API_BASE_URL=https://sentry.io/api/0
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=
SENTRY_DASHBOARD_ENVIRONMENTS=production,staging

## BullBoard
BULL_BOARD_PATH=/queues

## Notifications
## Set to 0 to disable automatic cleanup.
NOTIFICATION_RETENTION_DAYS=90

## Admin panels
NEST_LENS_ENABLED=true
ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=change-me

## File system
FILESYSTEM_DISK=public
AWS_REGION=
AWS_BUCKET=
AWS_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
