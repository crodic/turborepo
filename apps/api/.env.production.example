## Production example.
## Copy to .env on the server or provide these values through your deploy platform.
## Replace every change-me value before deployment.

APP_IMAGE=ghcr.io/owner/repository:main

NODE_ENV=production
TZ=UTC

APP_NAME="NestJS API"
APP_URL=https://api.example.com
APP_PORT=3000
APP_DEBUG=false
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_LOG_LEVEL=info
APP_LOG_SERVICE=console
APP_CORS_ORIGIN=https://example.com
APP_SECURE_HEADER_ORIGIN=https://example.com

DATABASE_TYPE=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USERNAME=change-me
DATABASE_PASSWORD=change-me
DATABASE_NAME=change-me
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_TLS_ENABLED=false

## Use a real SMTP service in production.
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=change-me
MAIL_PASSWORD=change-me
MAIL_IGNORE_TLS=false
MAIL_SECURE=false
MAIL_REQUIRE_TLS=true
MAIL_DEFAULT_EMAIL=noreply@example.com
MAIL_DEFAULT_NAME=No Reply

AUTH_JWT_SECRET=change-me
AUTH_JWT_TOKEN_EXPIRES_IN=1d
AUTH_REFRESH_SECRET=change-me
AUTH_REFRESH_TOKEN_EXPIRES_IN=365d
AUTH_FORGOT_SECRET=change-me
AUTH_FORGOT_TOKEN_EXPIRES_IN=15m
AUTH_CONFIRM_EMAIL_SECRET=change-me
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

USER_AUTH_JWT_SECRET=change-me
USER_AUTH_JWT_TOKEN_EXPIRES_IN=2m
USER_AUTH_REFRESH_SECRET=change-me
USER_AUTH_REFRESH_TOKEN_EXPIRES_IN=365d
USER_AUTH_FORGOT_SECRET=change-me
USER_AUTH_FORGOT_TOKEN_EXPIRES_IN=7d
USER_AUTH_CONFIRM_EMAIL_SECRET=change-me
USER_AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

AUTH_PORTAL_RESET_PASSWORD_URL=https://admin.example.com/reset-password
## Public origin of the client website. Used by API redirects after user OAuth/verification flows.
USER_AUTH_CLIENT_URL=https://example.com
## Client reset-password page used in user forgot-password emails.
USER_AUTH_CLIENT_RESET_PASSWORD_URL=https://example.com/reset-password

## Google OAuth app credentials for user/client login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
## Must match the authorized redirect URI configured in Google Cloud Console.
GOOGLE_OAUTH_CALLBACK_URL=https://api.example.com/api/v1/user/auth/social/google/callback

SENTRY_DNS_NESTJS=
SENTRY_ENVIRONMENT=production
SENTRY_API_BASE_URL=https://sentry.io/api/0
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=
SENTRY_DASHBOARD_ENVIRONMENTS=production,staging

BULL_BOARD_PATH=/queues

## Set to 0 to disable automatic notification cleanup.
NOTIFICATION_RETENTION_DAYS=90

NEST_LENS_ENABLED=false
ADMIN_PANEL_USERNAME=change-me
ADMIN_PANEL_PASSWORD=change-me
FEATURE_THEME_ENABLED=true

## File system
FILESYSTEM_DISK=public
AWS_REGION=local
AWS_BUCKET=local-bucket
AWS_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
