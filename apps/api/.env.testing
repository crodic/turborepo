NODE_ENV=test

APP_NAME="NestJS API"
APP_URL=http://localhost:8000
APP_PORT=8000
APP_DEBUG=false
API_PREFIX=api
APP_FALLBACK_LANGUAGE=en
APP_LOG_LEVEL=debug
APP_LOG_SERVICE=console
APP_CORS_ORIGIN=http://localhost:5173,http://localhost:3000
APP_SECURE_HEADER_ORIGIN=http://localhost:3000,http://localhost:5173

DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=boilerplate_test
DATABASE_LOGGING=true
DATABASE_SYNC=false
DATABASE_SYNCHRONIZE=false
DATABASE_MAX_CONNECTIONS=100
DATABASE_SSL_ENABLED=false
DATABASE_REJECT_UNAUTHORIZED=false
DATABASE_CA=
DATABASE_KEY=
DATABASE_CERT=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_IGNORE_TLS=true
MAIL_SECURE=false
MAIL_REQUIRE_TLS=false
MAIL_DEFAULT_EMAIL=noreply@example.com
MAIL_DEFAULT_NAME=No Reply
MAIL_CLIENT_PORT=1080

AUTH_JWT_SECRET=test-admin-jwt-secret
AUTH_JWT_TOKEN_EXPIRES_IN=1d
AUTH_REFRESH_SECRET=test-admin-refresh-secret
AUTH_REFRESH_TOKEN_EXPIRES_IN=365d
AUTH_FORGOT_SECRET=test-admin-forgot-secret
AUTH_FORGOT_TOKEN_EXPIRES_IN=15m
AUTH_CONFIRM_EMAIL_SECRET=test-admin-confirm-email-secret
AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d
AUTH_SUSPICIOUS_LOGIN_ENABLED=false

USER_AUTH_JWT_SECRET=test-user-jwt-secret
USER_AUTH_JWT_TOKEN_EXPIRES_IN=2m
USER_AUTH_REFRESH_SECRET=test-user-refresh-secret
USER_AUTH_REFRESH_TOKEN_EXPIRES_IN=365d
USER_AUTH_FORGOT_SECRET=test-user-forgot-secret
USER_AUTH_FORGOT_TOKEN_EXPIRES_IN=7d
USER_AUTH_CONFIRM_EMAIL_SECRET=test-user-confirm-email-secret
USER_AUTH_CONFIRM_EMAIL_TOKEN_EXPIRES_IN=1d

AUTH_PORTAL_RESET_PASSWORD_URL=http://localhost:5173/reset-password
USER_AUTH_CLIENT_URL=http://localhost:3000
USER_AUTH_CLIENT_RESET_PASSWORD_URL=http://localhost:3000/auth/reset-password

ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=test-admin-password

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:8000/api/v1/user/auth/social/google/callback

SENTRY_DNS_NESTJS=
SENTRY_ENVIRONMENT=test

SWAGGER_USERNAME=swagger
SWAGGER_PASSWORD=test-swagger-password

NEST_LENS_ENABLED=

BULL_BOARD_PATH=/queues
BULL_BOARD_USERNAME=bullboard
BULL_BOARD_PASSWORD=test-bullboard-password
NOTIFICATION_RETENTION_DAYS=90

FILESYSTEM_DISK=public

AWS_REGION=ap-southeast-1
AWS_BUCKET=test-bucket
AWS_ENDPOINT=https://s3.ap-southeast-1.amazonaws.com
AWS_ACCESS_KEY_ID=test-access-key
AWS_SECRET_ACCESS_KEY=test-secret-key
