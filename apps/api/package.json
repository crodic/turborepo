{
  "name": "nestjs-boilerplate",
  "version": "0.0.1",
  "description": "NestJS Boilerplate, Typescript, Postgres, TypeORM",
  "author": "crodic",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "test": "jest --config jest.config.json",
    "test:watch": "jest --config jest.config.json --watch",
    "test:cov": "jest --config jest.config.json --coverage",
    "test:ci": "jest --config jest.config.json --ci --runInBand --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config jest.config.json --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "env-cmd -- ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "typeorm:docker": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "pnpm typeorm --dataSource=src/database/data-source.ts migration:generate",
    "postmigration:generate": "pnpm lint",
    "migration:create": "pnpm typeorm -- migration:create",
    "migration:run": "pnpm typeorm --dataSource=src/database/data-source.ts migration:run",
    "migration:run:docker": "pnpm typeorm:docker --dataSource=src/database/data-source.ts migration:run",
    "migration:revert": "pnpm typeorm --dataSource=src/database/data-source.ts migration:revert",
    "migration:revert:docker": "pnpm typeorm:docker --dataSource=src/database/data-source.ts migration:revert",
    "schema:drop": "pnpm typeorm --dataSource=src/database/data-source.ts schema:drop",
    "db:create": "env-cmd -- ts-node -r tsconfig-paths/register ./src/database/create-database.ts",
    "db:create:docker": "ts-node -r tsconfig-paths/register ./src/database/create-database.ts",
    "seed:run:relational": "ts-node -r tsconfig-paths/register ./src/database/seeds/relational/run-seed.ts",
    "permissions:sync": "ts-node -r tsconfig-paths/register ./src/database/sync-permissions.ts",
    "migration:run:prod": "typeorm --dataSource=dist/database/data-source.js migration:run",
    "migration:revert:prod": "typeorm --dataSource=dist/database/data-source.js migration:revert",
    "seed:run:relational:prod": "node dist/database/seeds/relational/run-seed.js",
    "permissions:sync:prod": "node dist/database/sync-permissions.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@bull-board/api": "^6.21.3",
    "@bull-board/express": "^6.21.3",
    "@bull-board/nestjs": "^6.21.3",
    "@casl/ability": "^6.8.0",
    "@keyv/redis": "^5.1.6",
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.19",
    "@sentry/nestjs": "^10.48.0",
    "argon2": "^0.44.0",
    "axios": "^1.15.0",
    "bullmq": "^5.74.1",
    "cacheable": "^2.3.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "dotenv": "^17.4.2",
    "express-basic-auth": "^1.2.1",
    "handlebars": "^4.7.9",
    "helmet": "^8.1.0",
    "ms": "^2.1.3",
    "multer": "^2.1.1",
    "nestjs-cls": "^6.2.0",
    "nestjs-i18n": "^10.6.0",
    "nestjs-paginate": "^12.10.1",
    "nestjs-pino": "^4.6.1",
    "nestlens": "^0.4.1",
    "nodemailer": "^8.0.5",
    "otplib": "^13.4.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "qs": "^6.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "socket.io": "^4.8.3",
    "tslib": "^2.8.1",
    "typeorm": "^0.3.28",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.19",
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.26",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.20.0",
    "@types/qs": "^6.15.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "env-cmd": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "sass-embedded": "^1.99.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0"
  }
}
