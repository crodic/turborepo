<html lang='en'>
  <body style='margin:0;padding:0;background:#eef2f7;font-family:Arial,Helvetica,sans-serif;color:#111827;'>
    <table role='presentation' width='100%' cellspacing='0' cellpadding='0' style='background:#eef2f7;'>
      <tr>
        <td align='center' style='padding:40px 16px;'>
          <table role='presentation' width='100%' cellspacing='0' cellpadding='0' style='max-width:640px;background:#ffffff;border:1px solid #dbe3ef;border-radius:24px;overflow:hidden;box-shadow:0 20px 50px rgba(15,23,42,0.10);'>
            <tr>
              <td style='padding:30px 36px 24px;background:#0f172a;'>
                <span style='display:inline-block;width:40px;height:40px;border-radius:12px;background:#22c55e;text-align:center;line-height:40px;color:#ffffff;font-size:18px;font-weight:700;'>U</span>
                <span style='float:right;border:1px solid rgba(255,255,255,0.20);border-radius:999px;color:#bbf7d0;font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:8px 12px;'>Account verification</span>
              </td>
            </tr>
            <tr>
              <td style='padding:36px 36px 14px;'>
                <h1 style='margin:0;color:#111827;font-size:34px;line-height:42px;font-weight:800;'>Verify your email address</h1>
                <p style='margin:16px 0 0;color:#4b5563;font-size:16px;line-height:26px;'>Hi {{email}}, welcome aboard. Confirm your email address to finish setting up your account.</p>
              </td>
            </tr>
            <tr>
              <td style='padding:18px 36px 8px;'>
                <a href='{{url}}' target='_blank' style='display:inline-block;padding:15px 24px;background:#16a34a;color:#ffffff;font-size:15px;font-weight:700;text-decoration:none;border-radius:12px;'>Verify account</a>
              </td>
            </tr>
            <tr>
              <td style='padding:18px 36px 0;'>
                <p style='margin:0;color:#6b7280;font-size:14px;line-height:22px;'>If the button does not work, copy and paste this secure link into your browser:</p>
                <div style='margin-top:12px;padding:14px 16px;background:#f8fafc;border:1px solid #e5e7eb;border-radius:12px;color:#2563eb;font-size:13px;line-height:20px;word-break:break-all;'><a href='{{url}}' target='_blank' style='color:#2563eb;text-decoration:none;'>{{url}}</a></div>
              </td>
            </tr>
            <tr>
              <td style='padding:24px 36px 34px;'>
                <div style='background:#f0fdf4;border:1px solid #bbf7d0;border-radius:14px;padding:16px 18px;color:#166534;font-size:13px;line-height:21px;'>If you did not create this account, you can safely ignore this email.</div>
              </td>
            </tr>
            <tr>
              <td style='padding:22px 36px;background:#f8fafc;border-top:1px solid #e5e7eb;color:#6b7280;font-size:12px;line-height:20px;'>Sent by Crodic Portal. Please do not reply to this automated message.</td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
