<html lang='en'>
  <body
    style='margin:0;padding:0;background:#f1f5f9;font-family:Arial,Helvetica,sans-serif;color:#111827;'
  >
    <table
      role='presentation'
      width='100%'
      cellspacing='0'
      cellpadding='0'
      style='background:#f1f5f9;'
    >
      <tr>
        <td align='center' style='padding:40px 16px;'>
          <table
            role='presentation'
            width='100%'
            cellspacing='0'
            cellpadding='0'
            style='max-width:640px;background:#ffffff;border:1px solid #dbe3ef;border-radius:24px;overflow:hidden;box-shadow:0 20px 50px rgba(15,23,42,0.10);'
          >
            <tr>
              <td style='padding:30px 36px 24px;background:#0f172a;'>
                <span
                  style='display:inline-block;width:40px;height:40px;border-radius:12px;background:#f59e0b;text-align:center;line-height:40px;color:#111827;font-size:18px;font-weight:800;'
                >S</span>
                <span
                  style='float:right;border:1px solid rgba(255,255,255,0.20);border-radius:999px;color:#fde68a;font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:8px 12px;'
                >Support access</span>
              </td>
            </tr>
            <tr>
              <td style='padding:36px 36px 14px;'>
                <h1
                  style='margin:0;color:#111827;font-size:34px;line-height:42px;font-weight:800;'
                >A support session has started</h1>
                <p
                  style='margin:16px 0 0;color:#4b5563;font-size:16px;line-height:26px;'
                >Hi
                  {{#if userName}}{{userName}}{{else}}{{email}}{{/if}}, an
                  authorized administrator has started a temporary support
                  session for your account.</p>
              </td>
            </tr>
            <tr>
              <td style='padding:18px 36px 8px;'>
                <table
                  role='presentation'
                  width='100%'
                  cellspacing='0'
                  cellpadding='0'
                  style='background:#fffbeb;border:1px solid #fde68a;border-radius:16px;'
                >
                  <tr>
                    <td
                      style='padding:18px 20px;color:#92400e;font-size:14px;line-height:23px;'
                    >
                      <p style='margin:0 0 8px;'><strong>Administrator:</strong>
                        {{#if adminName}}{{adminName}}{{else}}Portal
                          administrator{{/if}}</p>
                      <p style='margin:0 0 8px;'><strong>Started at:</strong>
                        {{startedAt}}</p>
                      {{#if expiresAt}}<p style='margin:0 0 8px;'><strong
                          >Scheduled to expire:</strong>
                          {{expiresAt}}</p>{{/if}}
                      {{#if reason}}<p style='margin:0;'><strong
                          >Reason:</strong>
                          {{reason}}</p>{{/if}}
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            <tr>
              <td style='padding:22px 36px 34px;'>
                <p
                  style='margin:0;color:#4b5563;font-size:15px;line-height:24px;'
                >This access is intended for support, troubleshooting, or
                  account assistance. We will send another email when the
                  session ends with a friendly summary of any recorded actions.</p>
              </td>
            </tr>
            <tr>
              <td
                style='padding:22px 36px;background:#f8fafc;border-top:1px solid #e5e7eb;color:#6b7280;font-size:12px;line-height:20px;'
              >Sent by Crodic Portal. Please contact support if this activity
                does not look familiar.</td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>